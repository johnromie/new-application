# Database mode:
# - json: compatible with Hostinger Web/Cloud Node hosting
# - postgres: use for external/VPS PostgreSQL
DB_MODE=json

# IMPORTANT (production): use a path outside the deployed code folder
# so data survives every Git redeploy.
# Hostinger example (recommended):
# DB_PATH=../persistent-data/db.json
# Avoid:
# DB_PATH=./persistent-data/db.json
DB_PATH=./data/db.json

# Optional mirror/fallback copy (recommended in production).
# If DB_PATH is reset during deploy, server will recover from this mirror.
# Example:
# DB_MIRROR_PATH=../persistent-data/db-mirror.json
DB_MIRROR_PATH=

# OTP email delivery (Brevo)
BREVO_API_KEY=
BREVO_FROM=
BREVO_FROM_NAME=SDO Marinduque Attendance
OTP_EMAIL_REQUIRED=true
ALLOW_DEV_OTP_FALLBACK=false

# PostgreSQL settings (used only when DB_MODE=postgres)
# DATABASE_URL=postgres://user:pass@host:5432/dbname
PGHOST=localhost
PGPORT=5432
PGUSER=sdo_user
PGPASSWORD=sdo_pass
PGDATABASE=sdo_attendance

ALLOW_SEED=false
